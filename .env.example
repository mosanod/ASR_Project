# =============================================================================
# Speaker-ID ASR Pipeline — Environment Variables
# Copy to .env and adjust for your deployment
# All values override config.yaml via SPEAKER_ID__<section>__<key> pattern
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
SPEAKER_ID__APP__LOG_LEVEL=INFO
SPEAKER_ID__APP__LOG_FORMAT=json
SPEAKER_ID__APP__MAX_CALLS_BEFORE_RESTART=20
SPEAKER_ID__APP__WARMUP_ON_START=true

# -----------------------------------------------------------------------------
# Paths (usually don't need to change in Docker)
# -----------------------------------------------------------------------------
# SPEAKER_ID__PATHS__MODELS_DIR=/app/models
# SPEAKER_ID__PATHS__DATA_DIR=/app/data
# SPEAKER_ID__PATHS__KNOWN_VOICES_DIR=/app/known_voices

# -----------------------------------------------------------------------------
# ASR (Faster-Whisper)
# -----------------------------------------------------------------------------
SPEAKER_ID__ASR__MODEL=large-v3
SPEAKER_ID__ASR__LANGUAGE=ru
SPEAKER_ID__ASR__BEAM_SIZE=5
SPEAKER_ID__ASR__COMPUTE_TYPE=float16
SPEAKER_ID__ASR__DEVICE=cuda:0

# -----------------------------------------------------------------------------
# Diarization
# -----------------------------------------------------------------------------
SPEAKER_ID__DIARIZATION__EMBEDDING_MODEL=nvidia/ctn-titanet_large
SPEAKER_ID__DIARIZATION__BASE_SIMILARITY_THRESHOLD=0.75
SPEAKER_ID__DIARIZATION__USE_DYNAMIC_THRESHOLD=true
SPEAKER_ID__DIARIZATION__DYNAMIC_THRESHOLD_MULTIPLIER=2.5
SPEAKER_ID__DIARIZATION__PHONE_MATCH_BONUS=0.10

# -----------------------------------------------------------------------------
# Clustering
# -----------------------------------------------------------------------------
SPEAKER_ID__CLUSTERING__ENABLE_UNKNOWN_CLUSTERING=true
SPEAKER_ID__CLUSTERING__MIN_UNKNOWN_SEGMENTS=15

# -----------------------------------------------------------------------------
# Merger
# -----------------------------------------------------------------------------
SPEAKER_ID__MERGER__MAX_PAUSE_MS=1000
SPEAKER_ID__MERGER__OVERLAP_TOLERANCE=0.15
SPEAKER_ID__MERGER__VAD_AWARE_GROUPING=true

# -----------------------------------------------------------------------------
# LLM
# -----------------------------------------------------------------------------
SPEAKER_ID__LLM__ENABLED=true
SPEAKER_ID__LLM__MODEL_PATH=/app/models/llm/model.gguf
SPEAKER_ID__LLM__N_CTX=8192
SPEAKER_ID__LLM__N_GPU_LAYERS=-1
SPEAKER_ID__LLM__TEMPERATURE=0.0
SPEAKER_ID__LLM__CIRCUIT_BREAKER__ENABLED=true
SPEAKER_ID__LLM__CIRCUIT_BREAKER__FAILURE_THRESHOLD=5
SPEAKER_ID__LLM__CIRCUIT_BREAKER__RECOVERY_TIMEOUT_SECONDS=600

# -----------------------------------------------------------------------------
# Learning Loop
# -----------------------------------------------------------------------------
SPEAKER_ID__LEARNING__ENABLE_FEEDBACK_LOOP=true
SPEAKER_ID__LEARNING__MIN_CONFIDENCE_TO_ENROLL=0.85
SPEAKER_ID__LEARNING__MAX_VECTORS_PER_SPEAKER=50

# -----------------------------------------------------------------------------
# Qdrant
# -----------------------------------------------------------------------------
SPEAKER_ID__QDRANT__HOST=qdrant
SPEAKER_ID__QDRANT__PORT=6333
SPEAKER_ID__QDRANT__VECTOR_SIZE=192

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
SPEAKER_ID__REDIS__HOST=redis
SPEAKER_ID__REDIS__PORT=6379

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
SPEAKER_ID__MONITORING__ENABLED=true
SPEAKER_ID__MONITORING__PORT=9090
SPEAKER_ID__MONITORING__VRAM_LOG_INTERVAL_CALLS=5
SPEAKER_ID__MONITORING__VRAM_WARNING_THRESHOLD_GB=1.5

# -----------------------------------------------------------------------------
# NVIDIA / CUDA (usually set by docker-compose runtime)
# -----------------------------------------------------------------------------
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,utility
# CUDA_VISIBLE_DEVICES=0